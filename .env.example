# AutoVid — Environment Configuration
# Copy to backend/.env and fill in your values.
#
# Required keys are marked [required]. Optional keys have sensible defaults.

# ── License ───────────────────────────────────────────────────────────────────
# [required] Issued by the AutoVid author. Without this, the pipeline will not run.
AUTOVID_LICENSE_KEY=your-license-token-here

# ── Database (Supabase) ───────────────────────────────────────────────────────
# [required] Create a free project at https://supabase.com
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── LLM — Script & Label Generation (Groq) ───────────────────────────────────
# [required] Free tier: https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Secondary Groq key for stickfigure image generation (optional)
GROQ_API_KEY_2=
GROQ_IMAGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Text-to-Speech ────────────────────────────────────────────────────────────
# [required] TTS engine: "elevenlabs" (recommended) or "coqui" (local/free)
TTS_ENGINE=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
DEFAULT_ELEVENLABS_VOICE_ID=your-default-voice-id

# ── Stock Footage ─────────────────────────────────────────────────────────────
# [required] Free API: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# [optional] Fallback source: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ── YouTube ───────────────────────────────────────────────────────────────────
# [optional] Path to OAuth credentials downloaded from Google Cloud Console
# See README for one-time setup instructions
YOUTUBE_CLIENT_SECRETS_PATH=./client_secrets.json
YOUTUBE_TOKEN_PATH=./youtube_token.json
YOUTUBE_CHANNEL_ID=

# ── Authentication ────────────────────────────────────────────────────────────
# [required] Long random string used to sign JWTs — generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-generate-a-long-random-string

# Admin account (created on first run)
SUPERUSER_EMAIL=admin@your-domain.com
SUPERUSER_PASSWORD=change-me-strong-password

# Required to enable dangerous admin operations
DANGER_ZONE_KEY=

# ── Podcast Distribution ──────────────────────────────────────────────────────
BASE_URL=https://your-domain.com
PODCAST_TITLE=My AutoVid Podcast
PODCAST_DESCRIPTION=AI-generated stories narrated for your ears
PODCAST_IMAGE_URL=
PODCAST_AUTHOR=AutoVid
PODCAST_EMAIL=
PODCAST_CATEGORY=Society &amp; Culture
PODCAST_LANGUAGE=en-us
PODCAST_EXPLICIT=no

# Podbean (optional)
PODBEAN_CLIENT_ID=
PODBEAN_CLIENT_SECRET=

# Buzzsprout (optional)
BUZZSPROUT_API_TOKEN=

# ── Social Media ──────────────────────────────────────────────────────────────
# TikTok (optional)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Spotify (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Video Export ──────────────────────────────────────────────────────────────
VIDEO_RESOLUTION_W=1920
VIDEO_RESOLUTION_H=1080
VIDEO_FPS=30
VIDEO_BITRATE=5000k
AUDIO_BITRATE=192k

# ── Frontend branding (set in frontend/.env.local or .env.production) ─────────
# VITE_APP_NAME=AutoVid
# VITE_APP_URL=https://your-domain.com
# VITE_SUPPORT_EMAIL=support@your-domain.com
# VITE_CONTACT_EMAIL=contact@your-domain.com
# VITE_YOUTUBE_URL=https://www.youtube.com/@your-channel
# VITE_TIKTOK_URL=https://www.tiktok.com/@your-handle
# VITE_SPOTIFY_URL=https://open.spotify.com/show/your-show-id
# VITE_SPOTIFY_SHOW_ID=your-show-id

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Output paths (optional — defaults to backend/output/)
# VIDEOS_OUTPUT_DIR=/path/to/videos
# AUDIO_OUTPUT_DIR=/path/to/audio
# TEMP_DIR=/path/to/temp
