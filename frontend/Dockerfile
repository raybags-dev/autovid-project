FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# Accept VITE_* values at build time so they get baked into the JS bundle
ARG VITE_APP_NAME
ARG VITE_APP_URL
ARG VITE_SUPPORT_EMAIL
ARG VITE_CONTACT_EMAIL
ARG VITE_YOUTUBE_URL
ARG VITE_TIKTOK_URL
ARG VITE_SPOTIFY_URL
ARG VITE_SPOTIFY_SHOW_ID
ENV VITE_APP_NAME=$VITE_APP_NAME
ENV VITE_APP_URL=$VITE_APP_URL
ENV VITE_SUPPORT_EMAIL=$VITE_SUPPORT_EMAIL
ENV VITE_CONTACT_EMAIL=$VITE_CONTACT_EMAIL
ENV VITE_YOUTUBE_URL=$VITE_YOUTUBE_URL
ENV VITE_TIKTOK_URL=$VITE_TIKTOK_URL
ENV VITE_SPOTIFY_URL=$VITE_SPOTIFY_URL
ENV VITE_SPOTIFY_SHOW_ID=$VITE_SPOTIFY_SHOW_ID

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
